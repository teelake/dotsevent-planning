<IfModule mod_rewrite.c>
    # Site at domain root: RewriteBase /
    # Subfolder install (e.g. /new/): set RewriteBase /new/ and config base_url to match.
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L,QSA]
</IfModule>
