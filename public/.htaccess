<IfModule mod_rewrite.c>
    # Staging at https://dotseventplanning.com/new: if the site lives in a subfolder
    # and routes 404, try: RewriteBase /new/
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L,QSA]
</IfModule>
