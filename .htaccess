# Apache must point the site root here, or to /public/ with equivalent rules.
#
# Site at https://yoursite.com/new/ (config base_url = '/new'). For domain root, use RewriteBase / and base_url ''.

<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /new/

    RewriteRule ^index\.php$ - [L]
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]
    # Uploads are stored under public/uploads/ (PHP writes there); expose them at /new/uploads/…
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L,QSA]
</IfModule>
