# Serves the app at https://yoursite.com/new/ when this folder is public_html/new/
# (project root: index.php, app/, config/, public/…). If the URL path is not /new/,
# change  RewriteBase  and  config/app.php  base_url  to match.

<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /new/

    RewriteRule ^index\.php$ - [L]
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L,QSA]
</IfModule>
