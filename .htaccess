# Apache must point the site root here, or to /public/ with equivalent rules.
#
# A) Site at domain root (https://yoursite.com/…): set RewriteBase / and config base_url to ''.
# B) Staging in a subfolder (https://yoursite.com/new/…): set RewriteBase /new/ and config base_url to '/new'.

<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /

    RewriteRule ^index\.php$ - [L]
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L,QSA]
</IfModule>
